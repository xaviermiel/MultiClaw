# Chain selection: sepolia | base | base-sepolia
CHAIN=base

# RPC URL (defaults to public endpoint for selected chain if not set)
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Optional fallback RPC URLs (comma-separated)
# RPC_FALLBACK_URLS=https://rpc2.example.com,https://rpc3.example.com

# Private key of the authorized updater (must match AUTHORIZED_UPDATER in the module)
PRIVATE_KEY=0x...

# DeFiInteractorModule contract address
MODULE_ADDRESS=0x...

# Optional: ModuleRegistry address for multi-module support
# REGISTRY_ADDRESS=0x...

# Cron schedules
SAFE_VALUE_CRON="*/30 * * * * *"
SPENDING_ORACLE_CRON="*/5 * * * *"

# Event polling interval in milliseconds
# Defaults based on chain: Base ~4s (2x block time), Sepolia ~24s
# POLL_INTERVAL_MS=4000

# Blocks to look back for historical events
# Defaults based on chain: Base ~43200 (24h), Sepolia ~7200 (24h)
# BLOCKS_TO_LOOK_BACK=43200

# Window duration in seconds (default 24 hours)
WINDOW_DURATION_SECONDS=86400

# Gas limit for transactions
GAS_LIMIT=500000

# Reorg protection: blocks to wait before considering finalized
# Defaults based on chain: Base 3, Sepolia 12
# CONFIRMATION_BLOCKS=3
